{
  "expo": {
    "name": "tunda",
    "slug": "tunda",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tunda",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.th.maxim.tunda",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Wir benötigen Zugriff auf deine Fotos, damit du Fahrzeugbilder auswählen kannst.",
        "NSCameraUsageDescription": "Wir benötigen Zugriff auf die Kamera, damit du neue Fahrzeugbilder aufnehmen kannst.",
        "NSPhotoLibraryAddUsageDescription": "Wir benötigen Zugriff, um Bilder in deiner Mediathek speichern zu können."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.th.maxim.tunda"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Wir benötigen Zugriff auf deine Fotos, damit du Fahrzeugbilder auswählen kannst.",
          "cameraPermission": "Wir benötigen Zugriff auf die Kamera, damit du neue Fahrzeugbilder aufnehmen kannst."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
